# Copy this file to .env and fill in local values.
# Do not commit .env.

# LLM provider for graph extraction and optional evaluation.
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
JINA_API_KEY=your-jina-api-key

# Text embedding and policy models.
BGE_MODEL_PATH=BAAI/bge-large-en-v1.5
POLICY_MODEL_PATH=Qwen/Qwen2.5-VL-3B-Instruct

# Multimodal KB workspace and local embedding model. Supported backends are
# gme and qwen3-vl. The encoder loaders use local_files_only=True.
MM_DATA_ROOT=.
MM_EMBEDDING_BACKEND=gme
MM_EMBED_MODEL_PATH=/path/to/gme-Qwen2-VL-2B-Instruct
MM_EMBED_DEVICE=cuda
# MM_EMBEDDING_BACKEND=qwen3-vl
# MM_EMBED_MODEL_PATH=/path/to/Qwen3-VL-Embedding-2B

# Retrieval API endpoints.
TEXT_SEARCH_API_URL=http://127.0.0.1:8001/search
MM_SEARCH_API_URL=http://127.0.0.1:8003/search
MM_SEARCH_TIMEOUT=120

# Multimodal rollout context. Training code usually fills these automatically.
# EVOGRAPH_MM_CURRENT_IMAGE_ID=
# EVOGRAPH_MM_CURRENT_IMAGE_PATH=
# EVOGRAPH_MM_CURRENT_QUESTION=

# Editable multimodal KB working directory.
# EVOGRAPH_MM_WORKING_DIR=${MM_DATA_ROOT}/expr_mm/${MM_DATASET}_working_run

# Optional websearch cache. Use a separate namespace per dataset/subset, for
# example ${DATA_SOURCE} or ${MM_DATASET}_${MM_SUBSET}.
WEBSEARCH_CACHE_ENABLED=true
WEBSEARCH_CACHE_DIR=websearch_cache
# WEBSEARCH_CACHE_DATASET=${DATA_SOURCE}

# Deferred graph edit batching.
TOOL_USE_DEFERRED_EXECUTION=false
TOOL_BATCH_SIZE=50
TOOL_INSERT_BATCH_SIZE=10
